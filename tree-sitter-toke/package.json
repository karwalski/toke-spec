{
  "name": "tree-sitter-toke",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for the Toke programming language",
  "main": "bindings/node",
  "keywords": ["tree-sitter", "toke", "parser"],
  "repository": "github:karwalski/toke-spec",
  "license": "MIT",
  "dependencies": {
    "nan": "^2.18.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.22.0"
  },
  "scripts": {
    "build": "tree-sitter generate",
    "test": "tree-sitter test",
    "parse": "tree-sitter parse"
  },
  "tree-sitter": [
    {
      "scope": "source.toke",
      "file-types": ["tk"],
      "injection-regex": "^toke$"
    }
  ]
}
